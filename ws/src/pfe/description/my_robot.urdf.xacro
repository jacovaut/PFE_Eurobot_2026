<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="robot" >

    <xacro:include filename="include_tags.urdf.xacro" />

    <link name="world"></link>
    
    <joint name="base_joint" type="prismatic">
        <origin xyz="1.5 1.0 0.0617" rpy="0 0 0" />
        <parent link="world" />
        <child link="base_link" />
        <axis xyz="0.7071 0.7071 0"/>
        <limit lower="0.0" upper="1.0" effort="1000" velocity="0.5"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 .0025" rpy="0 0 0" />
            <geometry>
                <box size=".22 .24 .005" />
            </geometry>
            <material name="green">
                <color rgba="0.2 1 0.2 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 .0025" rpy="0 0 0" />
            <geometry>
                <box size=".22 .24 .005" />
            </geometry>
        </collision>

        
        <xacro:inertial_box mass="2.0" x=".22" y=".24" z=".005">
            <origin xyz="0 0 .0025" rpy="0 0 0" />
        </xacro:inertial_box>
    </link>

    <joint name="arducam_joint" type="fixed">
        <origin xyz="0 0 .626" rpy="-0.261799 0 0" />
        <parent link="base_link" />
        <child link="arducam_link" />    
    </joint>
    
    <link name="arducam_link">
        <visual>
            <origin xyz="0 0 .0025" rpy="0 0 0" />
            <geometry>
                <box size=".02 .02 .02" />
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1"/>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 .0025" rpy="0 0 0" />
            <geometry>
                <box size=".02 .02 .02" />
            </geometry>
        </collision>

        
        <xacro:inertial_box mass="0.1" x="0.02" y="0.02" z=".02">
            <origin xyz="0 0 .0025" rpy="0 0 0" />
        </xacro:inertial_box>

    </link>


    <!-- <xacro:include filename="example_gazebo.xacro" /> -->

</robot>









