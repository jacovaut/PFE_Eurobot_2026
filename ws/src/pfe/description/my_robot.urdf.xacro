<?xml version="1.0"?>
<robot name="pfe_robot">

  <!-- ===================== WORLD LINK ===================== -->
  <link name="world"/>

  <!-- ===================== BASE LINK ===================== -->
  <link name="Base-v1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- <mesh filename="package://pfe/meshes/Base-v1.stl" scale="0.001 0.001 0.001"/>-->
        
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/Base-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="Base-v1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ===================== MOUNT TO WHEEL LINKS ===================== -->
  <link name="MountToWheel-v1_a">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="MountToWheel-v1_b">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="MountToWheel-v1_c">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="MountToWheel-v1_d">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/MountToWheel-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== WHEEL JOINT LINKS ===================== -->
  <link name="WheelJoint-v1_a">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <link name="WheelJoint-v1_b">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <link name="WheelJoint-v1_c">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <link name="WheelJoint-v1_d">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/WheelJoint-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>

  <!-- ===================== ARDUCAM LINK ===================== -->
  <link name="arducam_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/arducam_link-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://pfe/meshes/arducam_link-v1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== JOINTS ===================== -->
  <!-- Base to MountToWheel -->
  <joint name="Base_to_MountToWheel_a" type="fixed">
    <parent link="Base-v1"/>
    <child link="MountToWheel-v1_a"/>
    <origin xyz="0.163 0.215 0.005" rpy="3.1416 0 3.1416"/>
  </joint>

  <joint name="Base_to_MountToWheel_b" type="fixed">
    <parent link="Base-v1"/>
    <child link="MountToWheel-v1_b"/>
    <origin xyz="0.035 0.215 0.005" rpy="0 0 3.1416"/>
  </joint>

  <joint name="Base_to_MountToWheel_c" type="fixed">
    <parent link="Base-v1"/>
    <child link="MountToWheel-v1_c"/>
    <origin xyz="0.077 0.005 0.005" rpy="0 0 3.1416"/>
  </joint>

  <joint name="Base_to_MountToWheel_d" type="fixed">
    <parent link="Base-v1"/>
    <child link="MountToWheel-v1_d"/>
    <origin xyz="0.205 0.005 0.005" rpy="3.1416 0 3.1416"/>
  </joint>

  <!-- MountToWheel to WheelJoint -->
  <joint name="MountToWheel_a_to_WheelJoint_a" type="continuous">
    <parent link="MountToWheel-v1_a"/>
    <child link="WheelJoint-v1_a"/>
    <origin xyz="0.021 0.0192 0.027" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="MountToWheel_b_to_WheelJoint_b" type="continuous">
    <parent link="MountToWheel-v1_b"/>
    <child link="WheelJoint-v1_b"/>
    <origin xyz="0.021 -0.0192 -0.027" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="MountToWheel_c_to_WheelJoint_c" type="continuous">
    <parent link="MountToWheel-v1_c"/>
    <child link="WheelJoint-v1_c"/>
    <origin xyz="-0.021 0.0192 -0.027" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="MountToWheel_d_to_WheelJoint_d" type="continuous">
    <parent link="MountToWheel-v1_d"/>
    <child link="WheelJoint-v1_d"/>
    <origin xyz="-0.021 -0.0192 0.027" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <!-- Base to Arducam -->
  <joint name="Base_to_arducam" type="fixed">
    <parent link="Base-v1"/>
    <child link="arducam_link"/>
    <origin xyz="0 0 0.626" rpy="-0.2618 0 0"/>
  </joint>

</robot>
